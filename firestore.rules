rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shipments: authenticated users can read/write
    match /shipments/{shipmentId} {
      allow read, write: if request.auth != null;
      // Cloud Functions can write
      allow write: if request.auth == null && request.time < timestamp.date(2025, 12, 31);
    }

    // Nodes: public read, admin-only write
    match /nodes/{nodeId} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK / Cloud Functions
    }

    // Routes: public read, admin-only write
    match /routes/{routeId} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK / Cloud Functions
    }

    // Alerts: authenticated users can read, Cloud Functions write
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if request.auth == null && request.resource.data.aiLog is string;
    }
  }
}
